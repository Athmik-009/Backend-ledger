<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="page-auth" data-page="system-login">
    <main class="auth-shell">
      <section class="card form-card">
        <h2>System access</h2>
        <p class="muted">Sign in as a system user to fund new accounts and review users.</p>
        <form id="systemLoginForm" novalidate autocomplete="off">
          <label>
            Email
            <input type="email" name="email" autocomplete="email" required />
            <p class="field-error" data-error-for="email"></p>
          </label>
          <label>
            Password
            <input type="password" name="password" autocomplete="current-password" required minlength="6" />
            <p class="field-error" data-error-for="password"></p>
          </label>
          <button class="btn btn-primary" type="submit">Sign in</button>
        </form>
        <p class="switch-link">
          <a class="btn btn-secondary" href="/">Back to home</a>
        </p>
        <p id="message" class="message" aria-live="polite"></p>
      </section>
    </main>
    <script src="/js/app.js"></script>
  </body>
</html>
